# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Train data: use one of the following.
# Option A — Mobiliteit.lu (HAFAS) real-time departures [recommended]:
#   Get API key: opendata-api@atp.etat.lu (https://data.public.lu/en/datasets/api-mobiliteit-lu/)
#   Set OPEN_DATA_API to the full departureBoard URL, e.g.:
#   OPEN_DATA_API=https://cdt.hafas.de/opendata/apiserver/departureBoard?accessId=YOUR_KEY&id=200405060&lang=en&format=json
#   (id=200405060 = Luxembourg Gare Centrale; use location.nearbystops to find other stop ids)
# OPEN_DATA_API=

# Option B — GTFS zip (no API key). Path to zip or URL.
# GTFS_URL=files/gtfs-20260225-20260430.zip

# Real-time delays (optional). Default: OpenOV GTFS-RT, refresh every 10 min.
# GTFS_RT_URL=
# REALTIME_REFRESH_SECONDS=600

# Auto-report interval in hours (0 to disable)
REPORT_INTERVAL_HOURS=3

# Logging
LOG_LEVEL=INFO
