# Train data: GTFS open data (no API key). Optional override for GTFS feed URL.
# Default: http://openov.lu/data/gtfs/gtfs-openov-lu.zip (may have limited date range)
# For current dates, download from data.public.lu (Horaires et arrêts GTFS) and set:
#   GTFS_URL=/path/to/gtfs.zip   or   GTFS_URL=file:///path/to/gtfs.zip
# GTFS_URL=

# Real-time delays: GTFS-RT trip updates (merged with GTFS schedule). Optional override.
# Default: http://openov.lu/gtfs-rt/tripUpdates.pb
GTFS_URL=http://openov.lu/data/gtfs/gtfs-openov-lu.zip
# How often to refresh delays (seconds). Default 600 (10 min).
# REALTIME_REFRESH_SECONDS=600

# Auto-report interval in hours (0 to disable)
REPORT_INTERVAL_HOURS=3

# Logging
LOG_LEVEL=INFO
